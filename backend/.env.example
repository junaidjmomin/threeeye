# ============================================================
# Third Eye — Backend Environment Variables
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
# Use sqlite+aiosqlite:///./thirdeye.db for local dev without Postgres
DATABASE_URL=postgresql+asyncpg://thirdeye:thirdeye_dev@localhost:5432/thirdeye
DATABASE_ECHO=false

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-byte-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# --- CORS ---
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# --- LLM Provider (Phase 2) ---
# Options: anthropic | openai | azure_openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Weaviate Vector DB (Phase 2) ---
WEAVIATE_URL=http://localhost:8081

# --- Signal Sources (Phase 2) ---
NEWS_API_KEY=
SHODAN_API_KEY=
HIBP_API_KEY=
NVD_API_KEY=

# --- AWS (Production — ap-south-1 for RBI data residency) ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_REPORTS=thirdeye-reports
S3_BUCKET_MODELS=thirdeye-models

# --- Consortium / Hyperledger Fabric (Phase 3) ---
FABRIC_NETWORK_ENABLED=false
FABRIC_PEER_ENDPOINT=grpcs://peer0.bank.thirdeye.network:7051
FABRIC_CHANNEL_NAME=vendor-risk-consortium
FABRIC_CHAINCODE_NAME=risk-agent

# --- Encryption (for PII fields at rest) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
