# ── Sepolia / Blockchain ──────────────────────────────────────────────────────

# Alchemy / Infura / public RPC — must be Sepolia (chain 11155111)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Private key of the wallet that will sign broadcastSignal() transactions
# Fund it with Sepolia ETH from: https://sepoliafaucet.com
BROADCASTER_PRIVKEY=0xYOUR_PRIVATE_KEY_HERE

# Deployed RiskConsortium contract address (from blockchain/deployments.json after deploy)
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# ── 0G Compute Network ────────────────────────────────────────────────────────

# Base URL of 0G serving endpoint (OpenAI-compatible)
# Testnet: https://inference.0g.ai/v1
ZG_SERVING_ENDPOINT=https://inference.0g.ai/v1

# API key / bearer token from 0G serving broker account
ZG_API_KEY=your_0g_api_key_here

# Model served by 0G (check available models at your endpoint)
ZG_MODEL=meta-llama/Llama-3-8b-instruct
